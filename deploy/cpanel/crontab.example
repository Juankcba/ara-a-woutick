# Crontab para el usuario cPanel. Pegar en cPanel → Cron Jobs.
# Antes: ajustar <CPANEL_USER> o usar $USER si la shell lo expande.
# Todos los tiempos son del server (configurado a Europe/Madrid en /etc/localtime).

# Silenciar los emails por default — usamos logs en disco.
MAILTO=""

# ──────────────────────────────────────────────────────────────────────
# Ticketmaster — cada 12h (00:00 y 12:00). API data, ~6 min por corrida.
0 0,12 * * *   /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh scrape ticketmaster >> /home/<CPANEL_USER>/logs/tm-scrape.log 2>&1 && /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh promote ticketmaster 5000 >> /home/<CPANEL_USER>/logs/tm-promote.log 2>&1

# ──────────────────────────────────────────────────────────────────────
# Taquilla — diario 03:00. HTML scraping, ~35 min por corrida.
0 3 * * *      /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh scrape taquilla >> /home/<CPANEL_USER>/logs/taquilla-scrape.log 2>&1 && /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh promote taquilla 5000 >> /home/<CPANEL_USER>/logs/taquilla-promote.log 2>&1

# ──────────────────────────────────────────────────────────────────────
# APM Musical — semanal lunes 04:00. Directorio estable, ~8s por corrida.
0 4 * * 1      /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh scrape apm_musical >> /home/<CPANEL_USER>/logs/apm-scrape.log 2>&1

# ──────────────────────────────────────────────────────────────────────
# Venues → leads_crm. Sincroniza todos los venues que los scrapers crearon
# en ticket_public.venues a leads_crm.companies con category='venue'.
# Diario 05:00 (después de Taquilla que es quien más venues genera).
0 5 * * *      /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh exec tsx bin/promote_venues_to_leads.ts >> /home/<CPANEL_USER>/logs/venues-promote.log 2>&1

# ──────────────────────────────────────────────────────────────────────
# Festivales → leads_crm. Extrae los nombres de festival de los events
# con category='festivales' y los agrupa como companies. Diario 05:10.
10 5 * * *     /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh exec tsx bin/promote_festivals_to_leads.ts >> /home/<CPANEL_USER>/logs/festivals-promote.log 2>&1

# ──────────────────────────────────────────────────────────────────────
# Discover websites — domain-guessing sobre empresas sin website.
# Martes 05:00 antes del contact-scrape (que consume lo que esto produce).
0 5 * * 2      /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh exec tsx bin/discover_websites.ts --limit 100 >> /home/<CPANEL_USER>/logs/discover.log 2>&1

# ──────────────────────────────────────────────────────────────────────
# Scrape contact pages — extrae emails + teléfonos + IG/FB/Twitter/LinkedIn
# de /contacto /prensa /equipo. Diario 05:30 — el query target del script
# salta a la siguiente empresa pendiente cada vez (companies con website
# que les falte cualquier contacto o social), así corre cuanto haga falta
# hasta consumir el backlog. --limit 50 para mantener cada corrida en
# ~10-12 min y no encimar con el dedup de los Martes.
30 5 * * *     /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh exec tsx bin/scrape_contact_pages.ts --limit 50 >> /home/<CPANEL_USER>/logs/contact-scrape.log 2>&1

# ──────────────────────────────────────────────────────────────────────
# Dedup companies. Idempotente (si no hay duplicados, no hace nada).
# Martes 05:45 después del contact-scrape.
45 5 * * 2     /home/<CPANEL_USER>/woutick-scrapers/deploy/cpanel/run.sh exec tsx bin/dedup_companies.ts --apply >> /home/<CPANEL_USER>/logs/dedup.log 2>&1

# ──────────────────────────────────────────────────────────────────────
# ECI entradas + Fever — NO corren en cPanel cron. Requieren Playwright
# + Chromium, y el VPS cPanel no tiene sudo para instalar las deps de
# sistema. Movidos a GitHub Actions:
#   .github/workflows/scrape-eci.yml   (cada 12h)
#   .github/workflows/scrape-fever.yml (diario 04:30 UTC)
# Ver deploy/cpanel/README.md sección "Scrapers en GitHub Actions".

# ──────────────────────────────────────────────────────────────────────
# Rotación de logs — semanal domingo 23:00. Mantiene los últimos 7 días.
0 23 * * 0     find /home/<CPANEL_USER>/logs -name "*.log" -type f -mtime +7 -delete
