# /home/<CPANEL_USER>/woutick-scrapers/.env
# Mismas vars que la .env de desarrollo, con DOS diferencias:
#
# 1. DB_HOST=localhost — el MySQL vive en el mismo server, conexión por
#    Unix socket (más rápido que TCP y no requiere Remote MySQL whitelist)
# 2. TIMEZONE del proceso — el server de cPanel debería estar en
#    Europe/Madrid; si no, setear TZ explícito para que las fechas
#    scrapeadas se guarden correctamente

TZ=Europe/Madrid

# === MySQL (local en el mismo cPanel) ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=dbwoutick_admin
DB_PASS=PEGAR_PASSWORD_AQUI

DB_PUBLIC=dbwoutick_ticket_public
DB_SCRAPING=dbwoutick_ticket_scraping
DB_LEADS=dbwoutick_leads_crm

# Prisma (el front Vercel usa la hostname pública con TLS; acá no hace falta).
# Si algún día corriera Prisma en el mismo server:
# DATABASE_URL_PUBLIC="mysql://dbwoutick_admin:PASS_URLENCODED@localhost:3306/dbwoutick_ticket_public"

# === APIs de ticketeras ===
TICKETMASTER_API_KEY=PEGAR_KEY_AQUI
TICKETMASTER_SECRET=PEGAR_SECRET_AQUI
