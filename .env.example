# Copiá este archivo a .env y completá con los valores reales.
# NUNCA comitear .env — ya está en .gitignore.

# === MySQL (cPanel, servidor 185.140.33.46) ===
DB_HOST=cpanel.woutick.es
DB_PORT=3306
DB_USER=dbwoutick_admin
DB_PASS=PEGAR_PASSWORD_AQUI

# Databases
DB_PUBLIC=dbwoutick_ticket_public
DB_SCRAPING=dbwoutick_ticket_scraping
DB_LEADS=dbwoutick_leads_crm

# URLs Prisma (útiles cuando montemos el front)
# OJO: si la password tiene @, #, /, :, ? o caracteres especiales, URL-encode:
#   @ → %40   # → %23   / → %2F   : → %3A   ? → %3F   ^ → %5E   { → %7B   + → %2B
DATABASE_URL_PUBLIC="mysql://dbwoutick_admin:PEGAR_PASSWORD_URLENCODED@cpanel.woutick.es:3306/dbwoutick_ticket_public"
DATABASE_URL_SCRAPING="mysql://dbwoutick_admin:PEGAR_PASSWORD_URLENCODED@cpanel.woutick.es:3306/dbwoutick_ticket_scraping"
DATABASE_URL_LEADS="mysql://dbwoutick_admin:PEGAR_PASSWORD_URLENCODED@cpanel.woutick.es:3306/dbwoutick_leads_crm"

# === APIs de ticketeras ===
# Consumer Key gratis en https://developer.ticketmaster.com/user/me/apps (tras crear una app)
TICKETMASTER_API_KEY=
